generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  email           String           @unique
  passwordHash    String
  role            String           // "Engineer", "Healthcare Professional", "Admin"
  city            String?
  institution     String?
  posts           Post[]
  meetingRequests MeetingRequest[]
  activityLogs    ActivityLog[]
  createdAt       DateTime         @default(now())
}

model Post {
  id                   String           @id @default(uuid())
  title                String
  domain               String
  requiredExpertise    String
  projectStage         String
  confidentialityLevel String
  city                 String
  description          String
  status               String           @default("Active") // "Draft", "Active", "Meeting Scheduled", "Partner Found", "Expired"
  ownerId              String
  owner                User             @relation(fields: [ownerId], references: [id])
  meetingRequests      MeetingRequest[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
}

model MeetingRequest {
  id          String   @id @default(uuid())
  requesterId String
  requester   User     @relation(fields: [requesterId], references: [id])
  postId      String
  post        Post     @relation(fields: [postId], references: [id])
  timeSlots   String
  message     String?
  ndaAccepted Boolean  @default(false)
  status      String   @default("Pending") // "Pending", "Scheduled", "Declined"
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  actionType   String
  targetEntity String?
  resultStatus String?
}
